# --- LLM ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Backend ---
BACKEND_CORS_ORIGINS=http://localhost:3000
APPROVER_DISPLAY_NAME=Demo Manager
# Set DEMO_MODE=true on public deployments to disable writeback approve/reject
DEMO_MODE=false

# --- Odoo (XML-RPC) ---
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_copilot
ODOO_USERNAME=admin
ODOO_PASSWORD=admin

# --- Postgres (read-only analytics) ---
PG_HOST=localhost
PG_PORT=5432
PG_DB=odoo_copilot
PG_USER=odoo
PG_PASSWORD=odoo

# --- Odoo Master Password (for DB management) ---
MASTER_PASSWORD=your_master_password_here
